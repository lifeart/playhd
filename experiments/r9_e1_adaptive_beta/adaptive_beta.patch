@@ def blend_anchor_cache(heavy_cache, compact_cache, beta):
     for i in list(heavy_cache.keys()):
         h = heavy_cache[i].astype(np.float32)
         c = compact_cache[i].astype(np.float32)
         heavy_cache[i] = np.clip(np.round(c + b * (h - c)), 0, 255).astype(np.uint8)
     return heavy_cache


+def select_anchor_beta(heavy_cache, compact_cache, params):
+    """R9-E1 per-CLIP GLOBAL adaptive beta for the anchor blend (DEFAULT OFF / opt-in).
+    Returns ONE scalar beta in [0.70, 0.85] from two NO-REFERENCE global signals computed on
+    the two SR caches the quality path ALREADY has (ZERO extra SR):
+      tex_comp = mean 7x7 local-luma-STD of the COMPACT HR cache  (degrade-ROBUST CONTENT
+                 texture -- high on real detail, low on smooth faces; survives heavy degrade
+                 where Canny edges collapse).
+      disag    = mean |heavy - compact| luma                       (DEGRADE drive -- x4plus
+                 over-sharpens synthetic noise/compression the compact net avoids => high
+                 disagreement; a CLEAN real codec keeps both nets in agreement => low).
+        s = clip((t_hi - tex_comp)/(t_hi - t_lo), 0, 1)  # 1 = SMOOTH content
+        d = clip((disag - d_lo)/(d_hi - d_lo), 0, 1)     # 1 = heavily (synthetically) degraded
+        beta = 0.85 - 0.15 * s * d
+    Pulls beta DOWN toward 0.70 ONLY on smooth + heavily-degraded clips (the ONLY cells with
+    measured headroom below 0.85); stays at 0.85 (the R8-E3 OOD-safe default) on textured
+    content (s~0) and clean/mild real-codec content (d~0). R9-E1: measured <= fixed-0.85 on all
+    23 cells, strictly better on the smooth heavily-degraded face (talkinghead heavy/gritty
+    -0.010/-0.013 LPIPS). NARROW + overfit-fragile (win on one content; d_lo must be hand-set
+    above the real-H.264 disagreement floor, NOT learnable from synthetic alone) -> DEFAULT OFF;
+    fixed-0.85 remains the recommended robust default. params=None -> return the fixed cfg beta.
+    `compact_cache` MUST be index-aligned with `heavy_cache` (region_gate['compact'] already is)."""
+    if params is None:
+        return params  # caller falls back to the fixed cfg beta (R8-E3) -> byte-identical
+    import cv2
+    t_lo, t_hi = float(params["t_lo"]), float(params["t_hi"])
+    d_lo, d_hi = float(params["d_lo"]), float(params["d_hi"])
+    texs, disags = [], []
+    for i in list(heavy_cache.keys()):
+        yc = cv2.cvtColor(compact_cache[i], cv2.COLOR_RGB2GRAY).astype(np.float32)
+        yh = cv2.cvtColor(heavy_cache[i], cv2.COLOR_RGB2GRAY).astype(np.float32)
+        mu = cv2.boxFilter(yc, -1, (7, 7))
+        var = np.maximum(cv2.boxFilter(yc * yc, -1, (7, 7)) - mu * mu, 0.0)
+        texs.append(float(np.sqrt(var).mean()))
+        disags.append(float(np.abs(yh - yc).mean()))
+    tex_comp = float(np.mean(texs)); disag = float(np.mean(disags))
+    s = min(max((t_hi - tex_comp) / max(t_hi - t_lo, 1e-6), 0.0), 1.0)
+    d = min(max((disag - d_lo) / max(d_hi - d_lo, 1e-6), 0.0), 1.0)
+    return float(0.85 - 0.15 * s * d)
+
