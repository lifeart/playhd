 # --------------------------------------------------------------------------- #
+# R8-E2: cheap UNSHARP-MASK fallback fill (default OFF; `amount=0.0` -> byte-identical). The
+# occlusion-fallback band is filled by upscaling the CURRENT LR frame (the warp is invalid there);
+# the deployed fill is bicubic (temporally smooth but soft). R8-E2 measured that a light unsharp of
+# that bicubic fill beats bicubic on full-reference PSNR/SSIM/LPIPS (synthetic /2 ground truth) at
+# truth-matching temporal dF, and STRICTLY dominates the compact-SR escalation lever (which HURTS
+# PSNR on genuine high motion -- hallucinated detail -- and raises tOF ~60%). Cost ~+1.2 ms per
+# non-anchor (on-device blur+lerp) vs the ~31 ms 720p warp floor -> real-time held. It is read ONLY
+# at fallback pixels (perframe is consumed only there), changes NO mask/threshold, and touches no
+# anchor (anchors are full SR, not base_hd) -> the fallback band is the only output that differs.
+# --------------------------------------------------------------------------- #
+_UNSHARP_GAUSS = {}   # (sigma, device, channels) -> (kx, ky, pad) separable gaussian kernels
+
+
+def _gpu_unsharp(bic_t, amount, sigma):
+    """bic_t: [1,3,H,W] float (0..255) device tensor. out = clamp(bic + amount*(bic - blur))."""
+    import torch
+    import torch.nn.functional as F
+    c = bic_t.shape[1]
+    key = (round(float(sigma), 4), str(bic_t.device), c)
+    ker = _UNSHARP_GAUSS.get(key)
+    if ker is None:
+        r = max(1, int(3 * sigma + 0.5))
+        x = torch.arange(-r, r + 1, dtype=torch.float32, device=bic_t.device)
+        k = torch.exp(-(x * x) / (2 * sigma * sigma))
+        k = (k / k.sum())
+        kx = k.view(1, 1, 1, -1).expand(c, 1, 1, k.shape[-1]).contiguous()
+        ky = k.view(1, 1, -1, 1).expand(c, 1, k.shape[-1], 1).contiguous()
+        ker = (kx, ky, k.shape[-1] // 2)
+        _UNSHARP_GAUSS[key] = ker
+    kx, ky, pad = ker
+    b = F.conv2d(bic_t, kx, padding=(0, pad), groups=c)
+    b = F.conv2d(b, ky, padding=(pad, 0), groups=c)
+    return (bic_t + amount * (bic_t - b)).clamp_(0.0, 255.0)
+
+
+def _cpu_unsharp(bic_u8, amount, sigma):
+    """bic_u8: HxWx3 uint8. cv2 gaussian unsharp -> HxWx3 uint8."""
+    blur = cv2.GaussianBlur(bic_u8, (0, 0), float(sigma))
+    return cv2.addWeighted(bic_u8, 1.0 + float(amount), blur, -float(amount), 0)
+
+
